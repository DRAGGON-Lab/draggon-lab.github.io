---
import BaseLayout from '../layouts/BaseLayout.astro';
import ButtonLink from '../components/ui/ButtonLink.astro';
import DBTLCycleDisplay from '../components/DBTLCycleDisplay.astro';
import { siteConfig } from '../data/siteConfig';

// B-DNA geometry: 10.5 base pairs per turn, 0.34 nm rise, 2 nm diameter.
// The backbone radius is 46px (= 1 nm), so 1 bp rise = 0.34 * 46 ~= 15.6px.
// The two backbones are offset 120deg around the cylinder, which splits the
// circle into a 120deg (minor groove) and 240deg (major groove) arc.
const BP_COUNT = 41;
const RISE = 15.6; // px of vertical rise per base pair
const TWIST = 360 / 10.5; // degrees of twist per base pair (~34.3)
const STRAND_OFFSET = 120; // degrees between the two backbones
const BEADS_PER_BP = 6; // backbone samples per base pair -> smooth ribbons
const centerY = (bp) => (bp - (BP_COUNT - 1) / 2) * RISE;

// Two continuous backbone strands, densely sampled so each reads as a ribbon.
const beadCount = (BP_COUNT - 1) * BEADS_PER_BP + 1;
const strand = (phaseOffset) =>
  Array.from({ length: beadCount }, (_, i) => {
    const bp = i / BEADS_PER_BP;
    return { y: centerY(bp), r: bp * TWIST + phaseOffset };
  });
const strandA = strand(0);
const strandB = strand(STRAND_OFFSET);

// Base-pair rungs bridge the strands as a chord (see .dna__rung in CSS).
const rungs = Array.from({ length: BP_COUNT }, (_, i) => ({
  y: centerY(i),
  r: i * TWIST,
}));

const researchAreas = [
  {
    title: 'Biological Software Foundations',
    desc: 'Reusable standards, data structures, software, and metadata for programmable biology.',
  },
  {
    title: 'Automated DBTL Workflows',
    desc: 'Programmatic design-build-test-learn workflows for genetic network engineering.',
  },
  {
    title: 'AI-Aided Biodesign',
    desc: 'Machine learning and hybrid models that improve design from standardized biological data.',
  },
  {
    title: 'Digital Twins of Living Systems',
    desc: 'Simulations connecting engineered systems with cells, organisms, communities, and environments.',
  },
  {
    title: 'Intelligent Genetic & Genomic Networks',
    desc: 'Biological architectures for sensing, computing, feedback, and decision-making in living systems.',
  },
];

const applications = [
  {
    title: 'Resilient crops',
    desc: 'Biodesign workflows for more nutritious, robust, and sustainable plant systems.',
  },
  {
    title: 'Microbiome therapeutics',
    desc: 'Programmable living systems that can sense, respond, and support healthier communities.',
  },
  {
    title: 'Reusable infrastructure',
    desc: 'Open tools and standards that make biological engineering easier to reproduce and extend.',
  },
];

const publications = [
  {
    title: 'PhD thesis',
    desc: 'Automated design, build, test, learn workflows to engineer synthetic genetic networks.',
  },
  { title: 'LOICA', desc: 'Design automation for genetic networks.' },
  {
    title: 'SBOL and metadata',
    desc: 'Standards-enabled infrastructure for reproducible biological engineering.',
  },
];

const labNotes = [
  {
    title: 'Launching the DRAGGON Lab website',
    desc: 'An invitation to build open AI-aided biodesign platforms.',
  },
  {
    title: 'What is biological software engineering?',
    desc: 'A research explainer for the lab identity.',
  },
  {
    title: 'From DBTL to AI-aided biodesign',
    desc: 'A software-platform note for the DRAGGON ecosystem.',
  },
];
---

<BaseLayout
  title="DRAGGON Lab"
  description="AI-aided biodesign platforms for programming biological systems."
>
  <div class="hero-band">
    <div class="dna-stage" aria-hidden="true">
      <div class="dna">
        {
          rungs.map((rung) => (
            <div class="dna__rung" style={`--dna-y:${rung.y}px;--dna-r:${rung.r}deg`} />
          ))
        }
        {
          strandA.map((bead) => (
            <div
              class="dna__bead dna__bead--a"
              style={`--dna-y:${bead.y}px;--dna-r:${bead.r}deg`}
            />
          ))
        }
        {
          strandB.map((bead) => (
            <div
              class="dna__bead dna__bead--b"
              style={`--dna-y:${bead.y}px;--dna-r:${bead.r}deg`}
            />
          ))
        }
      </div>
    </div>
    <section class="relative z-10 mx-auto max-w-7xl px-4 pt-20 pb-16">
      <p
        class="text-draggon-muted inline-flex items-center gap-2 text-[0.72rem] font-semibold tracking-[0.16em] uppercase"
        data-reveal
        style="--reveal-delay: 0ms"
      >
        <span class="bg-draggon-green inline-block h-1.5 w-1.5 rounded-full" aria-hidden="true"
        ></span>
        {siteConfig.affiliation}
      </p>
      <h1
        class="hero-title mt-5 max-w-4xl text-5xl text-slate-950 sm:text-6xl"
        data-reveal
        style="--reveal-delay: 80ms"
      >
        AI-aided biodesign platforms for <span class="hero-accent">programming</span> biological systems
      </h1>
      <p
        class="mt-7 max-w-2xl text-lg leading-8 text-slate-600"
        data-reveal
        style="--reveal-delay: 180ms"
      >
        We develop software, data, and automation workflows to engineer organisms with novel
        capabilities, from more nutritious and resilient crops to microbiome therapeutics.
      </p>
      <p class="mt-4 max-w-2xl text-sm text-slate-500" data-reveal style="--reveal-delay: 240ms">
        Developing, Researching, and Architecting Genetic and GenOmic Networks
      </p>
      <div class="mt-9 flex flex-wrap gap-3" data-reveal style="--reveal-delay: 300ms">
        <ButtonLink href="/research">Explore Research</ButtonLink>
        <ButtonLink href="/tools" variant="secondary">Explore Tools</ButtonLink>
      </div>
    </section>
  </div>

  {/* Research — sticky intro + numbered agenda rows (not cards) */}
  <section class="mx-auto max-w-7xl px-4 py-16 md:py-24">
    <div class="grid gap-10 md:grid-cols-[20rem_1fr] md:gap-16">
      <div class="md:sticky md:top-24 md:self-start">
        <h2 class="text-3xl tracking-tight text-slate-950">
          Programming biology with reusable platforms
        </h2>
        <p class="mt-4 leading-7 text-slate-600">
          DRAGGON Lab builds AI-aided biodesign platforms that connect biological software
          foundations, automated DBTL workflows, machine learning, digital twins, and genetic
          network engineering.
        </p>
        <a
          href="/research"
          class="link-arrow text-draggon-violet mt-6 inline-flex items-center gap-2 text-sm font-semibold"
        >
          Explore all research <span class="agenda-arrow" aria-hidden="true">→</span>
        </a>
      </div>
      <ol class="border-t border-slate-200">
        {
          researchAreas.map((area, i) => (
            <li>
              <a
                href="/research"
                class="agenda-row group grid grid-cols-[auto_1fr_auto] items-baseline gap-x-5 gap-y-1 border-b border-slate-200 px-2 py-6"
              >
                <span class="agenda-num text-2xl text-slate-400">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span>
                  <span class="group-hover:text-draggon-violet block text-lg font-semibold text-slate-950 transition-colors duration-200">
                    {area.title}
                  </span>
                  <span class="mt-1 block text-sm leading-6 text-slate-600">{area.desc}</span>
                </span>
                <span class="agenda-arrow text-lg" aria-hidden="true">
                  →
                </span>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  {/* Platform — the rich DBTL widget carries this section */}
  <section class="mx-auto max-w-7xl px-4 py-16">
    <div class="flex flex-col justify-between gap-4 md:flex-row md:items-end">
      <div class="max-w-2xl">
        <h2 class="text-3xl tracking-tight text-slate-950">
          A platform ecosystem for the DBTL cycle
        </h2>
        <p class="mt-4 text-slate-600">
          We build open, reusable software, standards-enabled metadata, and FAIR data workflows so
          that biological engineering can become more reproducible, collaborative, and programmable.
        </p>
      </div>
      <ButtonLink href="/tools" variant="secondary">View platform ecosystem</ButtonLink>
    </div>
    <div class="mt-8">
      <DBTLCycleDisplay />
    </div>
  </section>

  {/* Applications — full-bleed tonal band, text columns divided by rules */}
  <div class="section-tint">
    <section class="mx-auto max-w-7xl px-4 py-16 md:py-20">
      <h2 class="max-w-2xl text-3xl tracking-tight text-slate-950">
        Engineering organisms with useful capabilities
      </h2>
      <div class="mt-10 grid gap-10 md:grid-cols-3 md:gap-0 md:divide-x md:divide-slate-200">
        {
          applications.map((app) => (
            <div class="md:px-8 md:first:pl-0 md:last:pr-0">
              <span class="bg-draggon-green inline-block h-2 w-2 rounded-full" aria-hidden="true" />
              <h3 class="mt-4 text-lg font-semibold text-slate-950">{app.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600">{app.desc}</p>
            </div>
          ))
        }
      </div>
    </section>
  </div>

  {/* Recent outputs — two-column typographic index (publications + notes) */}
  <section class="mx-auto max-w-7xl px-4 py-16 md:py-24">
    <h2 class="text-3xl tracking-tight text-slate-950">Recent outputs</h2>
    <div class="mt-10 grid gap-x-16 gap-y-12 md:grid-cols-2">
      <div>
        <div class="flex items-baseline justify-between border-b border-slate-200 pb-3">
          <h3 class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">
            Publications
          </h3>
          <a
            href="/publications"
            class="link-arrow text-draggon-violet inline-flex items-center gap-1.5 text-xs font-semibold"
          >
            Browse all <span class="agenda-arrow" aria-hidden="true">→</span>
          </a>
        </div>
        <ul>
          {
            publications.map((p) => (
              <li>
                <a
                  href="/publications"
                  class="entry group flex gap-4 border-b border-slate-200 py-4"
                >
                  <span
                    class="bg-draggon-violet mt-2 h-1.5 w-1.5 shrink-0 rounded-full"
                    aria-hidden="true"
                  />
                  <span>
                    <span class="entry-title block font-semibold text-slate-950">{p.title}</span>
                    <span class="mt-1 block text-sm leading-6 text-slate-600">{p.desc}</span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <div class="flex items-baseline justify-between border-b border-slate-200 pb-3">
          <h3 class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">
            Lab Notes
          </h3>
          <a
            href="/lab-notes"
            class="link-arrow text-draggon-violet inline-flex items-center gap-1.5 text-xs font-semibold"
          >
            Read all <span class="agenda-arrow" aria-hidden="true">→</span>
          </a>
        </div>
        <ul>
          {
            labNotes.map((note) => (
              <li>
                <a href="/lab-notes" class="entry group flex gap-4 border-b border-slate-200 py-4">
                  <span
                    class="bg-draggon-green mt-2 h-1.5 w-1.5 shrink-0 rounded-full"
                    aria-hidden="true"
                  />
                  <span>
                    <span class="entry-title block font-semibold text-slate-950">{note.title}</span>
                    <span class="mt-1 block text-sm leading-6 text-slate-600">{note.desc}</span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  {/* Invitation — restrained bordered block on paper, accent left rule */}
  <section class="mx-auto max-w-7xl px-4 pb-24">
    <div
      class="border-l-draggon-violet relative overflow-hidden rounded-2xl border border-l-4 border-slate-200 bg-white p-8 md:p-10"
    >
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div class="max-w-2xl">
          <div class="flex items-center gap-2">
            <span class="bg-draggon-green signal-glow h-2 w-2 rounded-full" aria-hidden="true"
            ></span>
            <span class="text-xs font-semibold tracking-[0.16em] text-slate-500 uppercase">
              Join / Collaborate
            </span>
          </div>
          <h2 class="mt-3 text-2xl tracking-tight text-slate-950">
            Build open AI-aided biodesign platforms with us
          </h2>
          <p class="mt-3 text-slate-600">
            We welcome prospective students, postdocs, collaborators, funders, open-source
            contributors, and technically curious partners interested in programmable biological
            systems.
          </p>
        </div>
        <div class="flex flex-shrink-0 flex-wrap gap-3">
          <ButtonLink href="/join-collaborate">Join / Collaborate</ButtonLink>
          <ButtonLink href="mailto:contact@draggonlab.org" variant="secondary">Contact</ButtonLink>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
