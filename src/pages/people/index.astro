---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import SimpleCard from '../../components/cards/SimpleCard.astro';
import { includeEntryInEnvironment, sortEntriesByTitle } from '../../lib/contentFilters';

const entries = sortEntriesByTitle(
  (await getCollection('people')).filter(includeEntryInEnvironment),
);
---

<BaseLayout title="People" description="Meet DRAGGON Lab.">
  <section class="mx-auto max-w-7xl px-4 py-16">
    <h1 class="text-4xl font-bold tracking-tight text-slate-950">People</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">
      DRAGGON Lab will grow through interdisciplinary researchers, students, collaborators, and
      contributors.
    </p>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {
        entries.map((entry) => (
          <SimpleCard title={entry.data.title} eyebrow={entry.data.tags[0]}>
            {entry.data.summary}
          </SimpleCard>
        ))
      }
    </div>
  </section>
</BaseLayout>
