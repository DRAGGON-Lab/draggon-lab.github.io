---
const { title, href, eyebrow, id, class: className, ...rest } = Astro.props;
---

<article id={id} {...rest} class:list={['card rounded-2xl p-5', className, href && 'group']}>
  {
    eyebrow && (
      <p class="text-draggon-violet text-xs font-semibold tracking-wide uppercase">{eyebrow}</p>
    )
  }
  <h3 class="mt-2 flex flex-wrap items-center gap-2 text-lg font-semibold text-slate-950">
    {
      href ? (
        <a
          href={href}
          class="card-title-link focus-visible:outline-draggon-violet rounded focus-visible:outline-2 focus-visible:outline-offset-4"
        >
          {title}
        </a>
      ) : (
        <span>{title}</span>
      )
    }
    <slot name="titleSuffix" />
  </h3>
  <p class="mt-3 text-sm leading-6 text-slate-600"><slot /></p>
  {
    href && (
      <a
        href={href}
        class="text-draggon-violet focus-visible:outline-draggon-violet mt-4 inline-flex rounded text-sm font-semibold focus-visible:outline-2 focus-visible:outline-offset-4"
      >
        Read more →
      </a>
    )
  }
</article>
