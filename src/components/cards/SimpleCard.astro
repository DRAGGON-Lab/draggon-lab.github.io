---
const { title, href, eyebrow, id } = Astro.props;
---

<article id={id} class:list={['card rounded-xl p-5', href && 'group relative']}>
  {
    href && (
      <a
        href={href}
        class="focus-visible:outline-draggon-violet absolute inset-0 z-10 rounded-xl focus-visible:outline-2 focus-visible:outline-offset-2"
        aria-label={`Read more about ${title}`}
      />
    )
  }
  {
    eyebrow && (
      <p class="text-draggon-violet text-[0.7rem] font-semibold tracking-[0.14em] uppercase">
        {eyebrow}
      </p>
    )
  }
  <h3 class="mt-2 flex flex-wrap items-center gap-2 text-lg font-semibold text-slate-950">
    <span class:list={[href && 'group-hover:text-draggon-violet transition-colors duration-200']}>
      {title}
    </span>
    <slot name="titleSuffix" />
  </h3>
  <p class="mt-3 text-sm leading-6 text-slate-600"><slot /></p>
  {href && <p class="card-more mt-4 text-sm font-semibold">Read more</p>}
</article>
