---
import { mainNav } from '../../data/navigation';
import { siteConfig } from '../../data/siteConfig';
import ThemeToggle from '../ui/ThemeToggle.astro';
const path = Astro.url.pathname;
const isActiveNavItem = (href: string) => path === href || path.startsWith(`${href}/`);
---

<header class="sticky top-0 z-30 border-b border-slate-200/70 bg-white/90 backdrop-blur">
  <a class="sr-only focus:not-sr-only" href="#main-content">Skip to content</a>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
    <a href="/" class="font-bold tracking-tight text-slate-950">{siteConfig.labName}</a>
    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {
        mainNav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-full px-3 py-2 text-sm font-medium transition',
              isActiveNavItem(item.href)
                ? 'text-draggon-deep bg-violet-50 shadow-[inset_0_-2px_0_#39FF14]'
                : 'hover:text-draggon-deep text-slate-700 hover:bg-violet-50',
              item.cta && 'ml-2 border border-violet-200',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center gap-2">
      <ThemeToggle />
      <details class="md:hidden">
        <summary class="cursor-pointer rounded-full border border-slate-200 px-3 py-2 text-sm"
          >Menu</summary
        >
        <nav
          class="absolute top-14 right-4 left-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-xl"
          aria-label="Mobile navigation"
        >
          <div class="grid gap-2">
            {
              mainNav.map((item) => (
                <a
                  href={item.href}
                  class:list={[
                    'rounded-xl p-3',
                    item.cta ? 'border border-violet-200 bg-violet-50' : 'hover:bg-slate-50',
                  ]}
                >
                  <span class="block font-semibold text-slate-950">{item.label}</span>
                  <span class="block text-sm text-slate-600">{item.description}</span>
                </a>
              ))
            }
          </div>
          <div
            class="mt-4 flex flex-wrap gap-3 border-t border-slate-200 pt-3 text-sm text-slate-700"
          >
            <a href={siteConfig.githubOrg} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={siteConfig.googleScholar} target="_blank" rel="noopener noreferrer">Scholar</a>
            <a href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href="/lab-notes/rss.xml">RSS</a>
          </div>
        </nav>
      </details>
    </div>
  </div>
</header>
