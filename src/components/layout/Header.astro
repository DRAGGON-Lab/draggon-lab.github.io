---
import { mainNav } from '../../data/navigation';
import { siteConfig } from '../../data/siteConfig';
import AnimationToggle from '../ui/AnimationToggle.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';

const path = Astro.url.pathname;
const isActiveNavItem = (href: string) => path === href || path.startsWith(`${href}/`);
---

<header class="glass-header sticky top-0 z-30">
  <a
    class="sr-only rounded-full bg-white px-4 py-2 text-sm font-semibold text-slate-950 focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50"
    href="#main-content"
  >
    Skip to content
  </a>
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-3">
    <a
      href="/"
      class="brand-lockup focus-visible:outline-draggon-violet rounded-full focus-visible:outline-2 focus-visible:outline-offset-4"
      aria-label="DRAGGON Lab home"
    >
      <span class="brand-mark" aria-hidden="true">D</span>
      <span>
        <strong>{siteConfig.labName}</strong>
        <small>BioDesign OS</small>
      </span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {
        mainNav.map((item) => {
          const active = isActiveNavItem(item.href);

          return (
            <a
              href={item.href}
              aria-current={active ? 'page' : undefined}
              class:list={[
                'nav-pill rounded-full px-3 py-2 text-sm font-medium',
                active
                  ? 'nav-pill--active text-draggon-deep bg-violet-50 shadow-[inset_0_-2px_0_#39FF14]'
                  : 'hover:text-draggon-deep text-slate-700 hover:bg-violet-50/80',
                item.cta && 'ml-2 border border-violet-200/80 bg-white/60',
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="flex items-center gap-2">
      <AnimationToggle />
      <ThemeToggle />
      <details class="relative md:hidden">
        <summary class="menu-summary cursor-pointer rounded-full border border-slate-200 bg-white/70 px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm">
          Menu
        </summary>
        <nav
          class="mobile-menu absolute top-12 right-0 w-[min(22rem,calc(100vw-2rem))] rounded-3xl border border-slate-200 bg-white/95 p-3 shadow-2xl shadow-violet-950/10 backdrop-blur"
          aria-label="Mobile navigation"
        >
          <div class="grid gap-2">
            {
              mainNav.map((item) => (
                <a
                  href={item.href}
                  aria-current={isActiveNavItem(item.href) ? 'page' : undefined}
                  class:list={[
                    'rounded-2xl p-3 transition',
                    item.cta ? 'border border-violet-200 bg-violet-50' : 'hover:bg-slate-50',
                  ]}
                >
                  <span class="block font-semibold text-slate-950">{item.label}</span>
                  <span class="block text-sm leading-6 text-slate-600">{item.description}</span>
                </a>
              ))
            }
          </div>
          <div
            class="mt-4 flex flex-wrap gap-3 border-t border-slate-200 pt-3 text-sm text-slate-700"
          >
            <a href={siteConfig.githubOrg} target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href={siteConfig.googleScholar} target="_blank" rel="noopener noreferrer">Scholar</a>
            <a href={siteConfig.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href="/lab-notes/rss.xml">RSS</a>
          </div>
        </nav>
      </details>
    </div>
  </div>
</header>
