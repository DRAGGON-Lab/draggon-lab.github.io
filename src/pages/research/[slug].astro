---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import DraftBadge from '../../components/ui/DraftBadge.astro';
import { includeEntryInEnvironment, shouldShowDraftBadge } from '../../lib/contentFilters';

export async function getStaticPaths() {
  const entries = (await getCollection('research')).filter(includeEntryInEnvironment);

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const eyebrow = entry.data.tags[0];
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="mx-auto max-w-4xl px-4 py-16">
    <a
      href="/research/"
      class="text-draggon-violet hover:text-draggon-deep focus-visible:text-draggon-deep text-sm font-semibold"
    >
      ← Back to research
    </a>
    <header class="mt-8 border-b border-slate-200 pb-8">
      {
        eyebrow && (
          <p class="text-draggon-violet text-sm font-semibold tracking-wide uppercase">{eyebrow}</p>
        )
      }
      <h1
        class="mt-3 flex flex-wrap items-center gap-3 text-4xl font-bold tracking-tight text-slate-950"
      >
        {entry.data.title}
        {shouldShowDraftBadge(entry) && <DraftBadge />}
      </h1>
      {
        entry.data.summary && (
          <p class="mt-4 text-lg leading-8 text-slate-600">{entry.data.summary}</p>
        )
      }
      {
        entry.data.tags.length > 0 && (
          <ul class="mt-6 flex flex-wrap gap-2" aria-label="Research tags">
            {entry.data.tags.map((tag) => (
              <li class="text-draggon-violet rounded-full border border-violet-200 bg-violet-50 px-3 py-1 text-xs font-semibold">
                {tag}
              </li>
            ))}
          </ul>
        )
      }
    </header>
    <div class="prose mt-8 max-w-none text-slate-700">
      <Content />
    </div>
  </article>
</BaseLayout>
