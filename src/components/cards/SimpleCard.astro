---
const { title, href, eyebrow } = Astro.props;
---
<article class="card rounded-2xl p-5">
  {eyebrow && <p class="text-xs font-semibold uppercase tracking-wide text-draggon-violet">{eyebrow}</p>}
  <h3 class="mt-2 text-lg font-semibold text-slate-950">{href ? <a href={href}>{title}</a> : title}</h3>
  <p class="mt-3 text-sm leading-6 text-slate-600"><slot /></p>
</article>
