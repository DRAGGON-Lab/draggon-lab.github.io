---
import BaseLayout from '../layouts/BaseLayout.astro';
import ButtonLink from '../components/ui/ButtonLink.astro';
---
<BaseLayout title="Page not found">
  <section class="mx-auto max-w-3xl px-4 py-24 text-center">
    <h1 class="text-4xl font-bold">Page not found</h1>
    <p class="mt-4 text-slate-600">This page does not exist or has moved.</p>
    <div class="mt-8"><ButtonLink href="/">Go home</ButtonLink></div>
  </section>
</BaseLayout>
