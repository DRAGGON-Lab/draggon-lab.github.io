<button
  type="button"
  class="theme-toggle animation-toggle"
  aria-label="Disable animations"
  aria-pressed="true"
  aria-live="polite"
  data-animation-toggle
>
  <span class="animation-toggle__icon" aria-hidden="true"></span>
  <span class="theme-toggle__text" data-animation-toggle-label>Animations</span>
</button>

<script>
  const animationStorageKey = 'draggon-animations';
  type AnimationPreference = 'on' | 'off';

  function storedAnimationPreference(): AnimationPreference {
    return localStorage.getItem(animationStorageKey) === 'off' ? 'off' : 'on';
  }

  function applyAnimationPreference(preference: AnimationPreference) {
    const enabled = preference === 'on';
    document.documentElement.dataset.animations = preference;
    document.documentElement.classList.toggle('animations-off', !enabled);

    if (!enabled) {
      document.querySelectorAll('.hero-neon-text--active').forEach((hero) => {
        hero.classList.remove('hero-neon-text--active');
      });
    }

    document.querySelectorAll('[data-animation-toggle]').forEach((toggle) => {
      const label = toggle.querySelector('[data-animation-toggle-label]');
      if (label) label.textContent = 'Animations';
      toggle.setAttribute('aria-pressed', String(enabled));
      toggle.setAttribute('aria-label', enabled ? 'Disable animations' : 'Enable animations');
    });
  }

  applyAnimationPreference(storedAnimationPreference());

  document.querySelectorAll('[data-animation-toggle]').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const preference: AnimationPreference = storedAnimationPreference() === 'on' ? 'off' : 'on';
      localStorage.setItem(animationStorageKey, preference);
      applyAnimationPreference(preference);
    });
  });
</script>
