---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import SimpleCard from '../../components/cards/SimpleCard.astro';
import DraftBadge from '../../components/ui/DraftBadge.astro';
import {
  includeEntryInEnvironment,
  shouldShowDraftBadge,
  sortEntriesByTitle,
} from '../../lib/contentFilters';

const entries = sortEntriesByTitle(
  (await getCollection('research')).filter(includeEntryInEnvironment),
);
---

<BaseLayout title="Research" description="Explore the DRAGGON Lab research vision.">
  <section class="mx-auto max-w-7xl px-4 py-16">
    <h1 class="text-4xl font-bold tracking-tight text-slate-950">Research</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">
      DRAGGON Lab builds AI-aided biodesign platforms across biological software foundations, DBTL
      workflows, machine learning, digital twins, and intelligent genetic networks.
    </p>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {
        entries.map((entry) => (
          <SimpleCard
            title={entry.data.title}
            eyebrow={entry.data.tags[0]}
            href={`/research/${entry.id}/`}
          >
            {shouldShowDraftBadge(entry) && <DraftBadge slot="titleSuffix" />}
            {entry.data.summary}
          </SimpleCard>
        ))
      }
    </div>
  </section>
</BaseLayout>
