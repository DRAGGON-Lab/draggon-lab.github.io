---
import { getCollection } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import SimpleCard from '../../components/cards/SimpleCard.astro';
import DraftBadge from '../../components/ui/DraftBadge.astro';
import {
  includeEntryInEnvironment,
  shouldShowDraftBadge,
  sortEntriesByTitle,
} from '../../lib/contentFilters';

const entries = sortEntriesByTitle(
  (await getCollection('lab-notes')).filter(includeEntryInEnvironment),
);
---

<BaseLayout title="Lab Notes" description="Research logs from DRAGGON Lab.">
  <section class="mx-auto max-w-7xl px-4 py-16">
    <h1 class="text-4xl font-bold tracking-tight text-slate-950">Lab Notes</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-600">
      Lab Notes are research logs from DRAGGON Lab: research explainers, software updates,
      tutorials, paper notes, teaching reflections, and invitations to collaborate.
    </p>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {
        entries.map((entry) => (
          <SimpleCard id={entry.id} title={entry.data.title} eyebrow={entry.data.tags[0]}>
            {shouldShowDraftBadge(entry) && <DraftBadge slot="titleSuffix" />}
            {entry.data.summary}
          </SimpleCard>
        ))
      }
    </div>
  </section>
</BaseLayout>
