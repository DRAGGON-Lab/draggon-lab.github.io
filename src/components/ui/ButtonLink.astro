---
type Variant = 'primary' | 'secondary' | 'subtle';

type Props = {
  href: string;
  variant?: Variant;
};

const { href, variant = 'primary' } = Astro.props as Props;

const variants: Record<Variant, string> = {
  primary: 'btn-primary bg-draggon-violet text-white hover:bg-draggon-deep',
  secondary:
    'border border-violet-200 text-draggon-deep hover:border-draggon-violet hover:bg-violet-50',
  subtle: 'border border-violet-200/70 text-white hover:border-white/80 hover:bg-white/10',
};
---

<a
  href={href}
  class:list={[
    'btn inline-flex items-center rounded-lg px-5 py-3 text-sm font-semibold',
    variants[variant] ?? variants.primary,
  ]}
>
  <slot />
</a>
